NODE_ENV=production
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
REDIS_URL=redis://default:password@redis.railway.internal:6379
AI_CORE_SHARED_SECRET=replace-with-ai-core-shared-secret
AI_PIPELINE_MODE=railway_remote
AI_INLINE_FALLBACK_ENABLED=false
NEXTSTOP_WEB_APP_URL=https://your-frontend-domain
DEEPGRAM_API_KEY=replace-with-deepgram-api-key
OPENAI_API_KEY=replace-with-openai-api-key
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
NOTION_CLIENT_ID=replace-with-notion-client-id
NOTION_CLIENT_SECRET=replace-with-notion-client-secret
NOTION_OAUTH_STATE_SECRET=replace-with-notion-oauth-state-secret
NOTION_REDIRECT_URI=https://your-railway-backend-domain/api/workspace/notion/callback
RAZORPAY_KEY_ID=rzp_test_public_key_id
RAZORPAY_KEY_SECRET=replace-with-razorpay-secret
RAZORPAY_PLAN_ID=replace-with-razorpay-plan-id
RAZORPAY_WEBHOOK_SECRET=replace-with-webhook-secret
SUPABASE_MEETING_AUDIO_BUCKET=meeting-audio
SUPABASE_MEETING_TRANSCRIPT_BUCKET=meeting-transcripts
TRANSCRIPT_STORAGE_MODE=disabled
TRANSCRIPT_RETENTION_MINUTES=60
RAW_ASSET_RETENTION_HOURS=24
SENTRY_DSN=https://public-key@your-sentry-domain/project-id
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=replace-with-release-version
SENTRY_TRACES_SAMPLE_RATE=0.05
OTEL_SERVICE_NAME=nextstop-ai-core-api
OTEL_EXPORTER_OTLP_ENDPOINT=https://your-otlp-collector.example.com/v1/traces
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic replace-with-basic-auth-token
GRAFANA_CLOUD_PROM_REMOTE_WRITE_URL=https://your-prometheus-remote-write.example.com/api/prom/push
GRAFANA_CLOUD_LOKI_URL=https://your-loki.example.com/loki/api/v1/push
GRAFANA_CLOUD_TEMPO_ENDPOINT=https://your-tempo-otlp.example.com/otlp
