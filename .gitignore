# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
**/coverage
**/playwright-report
**/test-results
/artifacts
backend/backend-vitest-results.json

# next.js
**/.next/
**/out/

# production
**/build
**/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files (can opt-in for committing if needed)
.env*
!.env.example
!frontend/.env.vercel.example
!backend/.env.railway.example
!backend/.env.local.example
!frontend/.env.local.example

# local-only stack files
backend/.env.local
frontend/.env.local
.env.local.stack
docker-compose.override.yml
docker-compose.dev.override.yml
docker-logs/
*.local.log

# vercel
**/.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local helper artifacts
generate_history.js
git_commit_history.md
local-stack-access.txt
dev-check.log
webpack-dev.log
tmp_template_export.pdf
frontend/output/
frontend/.playwright-cli/

# internal or sensitive project documentation
docs/*
!docs/*readiness*audit*.md
!docs/*production-readiness*.md
!docs/dependency-risk-acceptance*.md
!docs/abuse-control-inventory*.md
!docs/release-verification*.md

# local backend helper state
backend/supabase/.temp/
